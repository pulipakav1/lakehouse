# AWS credentials — create an IAM user with S3 read/write on your bucket
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET=your-lakehouse-bucket-name

# Airflow — generate a fernet key once and keep it stable:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=your-generated-fernet-key-here

# Airflow webserver secret key (any long random string)
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-to-a-long-random-string

# Match the UID of the user running Docker (run: id -u)
AIRFLOW_UID=50000
